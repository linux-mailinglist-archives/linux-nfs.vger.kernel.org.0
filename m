-static void rfc8009_encrypt_case(struct kunit *test)
-{
-	const struct gss_krb5_test_param *param = test->param_value;
-	struct crypto_sync_skcipher *cts_tfm, *cbc_tfm;
-	const struct gss_krb5_enctype *gk5e;
