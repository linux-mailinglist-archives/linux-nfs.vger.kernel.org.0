-
-	Ki.len = gk5e->Ki_length;
-	Ki.data = kunit_kzalloc(test, Ki.len, GFP_KERNEL);
-	KUNIT_ASSERT_NOT_ERR_OR_NULL(test, Ki.data);
-	usage.data[4] = KEY_USAGE_SEED_INTEGRITY;
